def delete_customer(self, customer_id):

    conn = get_connection()
    cursor = conn.cursor()

    cursor.execute(
        """
        DELETE FROM Customer
        WHERE customer_id = ?
        """,
        (customer_id,)
    )

    conn.commit()

    cursor.close()
    conn.close()

    print("Customer Deleted Successfully")
